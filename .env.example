# メール承認フロー用設定テンプレート
# 実際のメール送受信を行う場合は、このファイルをコピーして .env を作成し、適切な値を設定してください。

# 承認依頼を送信し、返信を受信するボットのメールアドレス設定
SENDER_EMAIL=your-bot-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# SMTPサーバー（送信）設定 (デフォルトはGmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# IMAPサーバー（受信）設定 (デフォルトはGmail)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# 承認者のメールアドレス
APPROVER_EMAIL=makoto.insidesales@gmail.com
