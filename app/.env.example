# ==========================================
# Secure AI Network - Local Configuration Template
# ==========================================

# 1. 動作モード設定
# True にすると実際のクラウドAPIを呼び出さずに、DLPマスキングと疑似応答で動作確認が可能です (ローカルテスト用)
USE_MOCK_AI=True

# 2. Azure OpenAI 設定 (実機API接続時に必要)
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# 3. GCP Vertex AI 設定 (実機API接続時に必要)
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_LOCATION=us-central1
GCP_VERTEX_MODEL=gemini-1.5-pro
